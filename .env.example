# ══════════════════════════════════════════════
# ReceiptAI — Variáveis de Ambiente
# Copie para .env.local e preencha com seus valores
# ══════════════════════════════════════════════

# ── JWT (gere com: openssl rand -base64 64) ───────────────────────────────────
JWT_SECRET=troque_por_string_aleatoria_de_64_caracteres_minimo

# ── Supabase ──────────────────────────────────────────────────────────────────
# Encontre em: Supabase → Settings → API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Groq (IA gratuita) ────────────────────────────────────────────────────────
# Crie grátis em: console.groq.com → API Keys → Create API Key
# Sem cartão de crédito — 14.400 tokens/dia + 30 req/min grátis
GROQ_API_KEY=gsk_...

# ── Ambiente ──────────────────────────────────────────────────────────────────
NODE_ENV=production
