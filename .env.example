# ── Autenticação JWT (gere um valor aleatório longo) ──────────────────────────
JWT_SECRET=troque_por_string_aleatoria_de_64_caracteres_minimo

# ── Supabase ──────────────────────────────────────────────────────────────────
# Encontre em: Supabase > Settings > API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Google Cloud Vision ───────────────────────────────────────────────────────
# Encontre em: Google Cloud Console > APIs & Services > Credentials > API Keys
GOOGLE_VISION_API_KEY=AIzaSy...

# ── Ambiente ──────────────────────────────────────────────────────────────────
NODE_ENV=production
